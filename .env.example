# Django runtime
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-long-random-local-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
DJANGO_SECURE_SSL_REDIRECT=false

# CORS for local Vue dev server
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Vue frontend API endpoints
VITE_API_ORIGIN=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# MySQL local development
MYSQL_DATABASE=property_management
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-local-mysql-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
